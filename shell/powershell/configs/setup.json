{
    "settings": {
        "execution_policy": "RemoteSigned",
        "winget_args": "--accept-package-agreements --accept-source-agreements"
    },
    "pre_install_commands": [
        {
            "enabled": true,
            "name": "Upgrade Winget to Latest Version",
            "command": "winget upgrade winget --accept-package-agreements --accept-source-agreements"
        }
    ],
    "winget": [
        {
            "source": "msstore",
            "packages": [
                "9nksqgp7f2nh",
                "xpfftq032ptphf",
                "9n45nsm4tnbp",
                "9p8ltpgcbzxd"
            ]
        },
        {
            "source": "winget",
            "packages": [
                "Brave.Brave",
                "Mozilla.Firefox",
                "xanderfrangos.twinkletray",
                "HermannSchinagl.LinkShellExtension",
                "Notepad++.Notepad++",
                "voidtools.Everything.Alpha",
                "CodeSector.TeraCopy",
                "qBittorrent.qBittorrent",
                "Flow-Launcher.Flow-Launcher",
                "SumatraPDF.SumatraPDF",
                "Obsidian.Obsidian",
                "AdrienAllard.FileConverter",
                "Microsoft.PowerToys",
                "ente-io.auth-desktop",
                "Cloudflare.Warp",
                "Tonec.InternetDownloadManager",
                "ONLYOFFICE.DesktopEditors",
                "eMClient.eMClient",
                "th-ch.YouTubeMusic",
                "Microsoft.PowerShell",
                "Notion.Notion"
            ]
        }
    ],
    "scoop": {
        "buckets": [
            {
                "name": "extras"
            },
            {
                "name": "versions"
            },
            {
                "name": "nerd-fonts"
            },
            {
                "name": "java"
            },
            {
                "name": "personal",
                "url": "https://github.com/fahim-ahmed05/scoop-bucket"
            }
        ],
        "packages": [
            "7zip",
            "aria2",
            "fastfetch",
            "nodejs",
            "aimp",
            "python",
            "quicklook",
            "revouninstaller",
            "mrrss",
            "syncthing",
            "trafficmonitor-lite",
            "winaero-tweaker",
            "yt-dlp",
            "versions/ffmpeg-yt-dlp-nightly",
            "uv",
            "mpv-git",
            "alacritty",
            "telegram",
            "ayugram",
            "foobar2000",
            "foobar2000-encoders",
            "localsend",
            "logitech-omm",
            "personal/clickpaste",
            "personal/winhance",
            "personal/stremio-kai",
            "personal/inter-font",
            "nerd-fonts/JetBrainsMono-NF",
            "nerd-fonts/CascadiaMono-NF",
            "oh-my-posh",
            "eza",
            "fzf",
            "zoxide",
            "microsoft-jdk",
            "musicbee"
        ]
    },
    "uv": {
        "tools": [
            "internetarchive",
            "subliminal"
        ]
    },
    "post_install_commands": [
        {
            "name": "Import Git Package List",
            "pwsh": true,
            "files": [
                {
                    "var": "{{script}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/gitpkg/main/gitpkg.ps1"
                },
                {
                    "var": "{{file}}",
                    "path": "D:\\Backups\\Gigabyte A520M\\Configs\\gitpkg\\gitpkg.json"
                }
            ],
            "command": "& '{{script}}' import '{{file}}'"
        },
        {
            "name": "Link dotfiles",
            "admin": true,
            "pwsh": true,
            "files": [
                {
                    "var": "{{script}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/dotmngr/main/dotmngr.ps1"
                },
                {
                    "var": "{{config}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/dotfiles/main/other/dotmngr/gigabyte.json"
                }
            ],
            "command": "& '{{script}}' -ConfigPath '{{config}}'"
        },
        {
            "name": "Enable SSH Agent",
            "admin": true,
            "command": "Get-Service -Name ssh-agent | Set-Service -StartupType Manual; Start-Service ssh-agent"
        },
        {
            "name": "Add GitHub Auth Key",
            "command": "ssh-add '%USERPROFILE%\\.ssh\\github_auth'"
        },
        {
            "name": "Add GitHub Sign Key",
            "command": "ssh-add '%USERPROFILE%\\.ssh\\github_sign'"
        },
        {
            "name": "Apply Registry Fix: Edge Policies",
            "admin": true,
            "files": [
                {
                    "var": "{{file}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/dotfiles/main/browser/msedge/polices.reg"
                }
            ],
            "command": "reg.exe import '{{file}}'"
        },
        {
            "name": "Apply Registry Fix: Brave Policies",
            "admin": true,
            "files": [
                {
                    "var": "{{file}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/dotfiles/main/browser/brave/polices.reg"
                }
            ],
            "command": "reg.exe import '{{file}}'"
        },
        {
            "name": "Apply Registry Fix: MPC-HC Settings",
            "files": [
                {
                    "var": "{{file}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/dotfiles/main/other/mpc-hc/mpc-hc-settings.reg"
                }
            ],
            "command": "reg.exe import '{{file}}'"
        },
        {
            "name": "Apply Registry Fix: Add 7-Zip to Context Menu",
            "command": "reg import '%USERPROFILE%\\scoop\\apps\\7zip\\current\\install-context.reg'"
        },
        {
            "name": "Apply Registry Fix: Make Python Available to System",
            "command": "reg import '%USERPROFILE%\\scoop\\apps\\python\\current\\install-pep-514.reg'"
        },
        {
            "name": "Apply Registry Fix: Disable OneDrive Personal",
            "files": [
                {
                    "var": "{{file}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/dotfiles/main/windows/onedrive/DisableOneDrivePersonal.reg"
                }
            ],
            "command": "reg.exe import '{{file}}'"
        },
        {
            "name": "Apply Registry Fix: Silent Windows Update",
            "files": [
                {
                    "var": "{{file}}",
                    "path": "https://raw.githubusercontent.com/fahim-ahmed05/dotfiles/main/windows/registry/SilentWindowsUpdate.reg"
                }
            ],
            "command": "reg.exe import '{{file}}'"
        },
        {
            "name": "Apply Registry Fix: Add Alacritty to Context Menu",
            "command": "reg import '%USERPROFILE%\\scoop\\apps\\alacritty\\current\\install-context.reg'"
        },
        {
            "name": "Disable Oh My Posh Update Notices",
            "command": "oh-my-posh disable notice"
        },
        {
            "name": "Activate Windows",
            "command": "irm 'https://get.activated.win' | iex"
        },
        {
            "name": "Chris Titus WinUtil",
            "admin": true,
            "command": "irm https://christitus.com/win | iex"
        },
        {
            "name": "Clean Up Desktop Shortcuts",
            "admin": true,
            "command": "Remove-Item -Path $env:USERPROFILE\\Desktop\\*.lnk, $env:PUBLIC\\Desktop\\*.lnk, $env:USERPROFILE\\Desktop\\*.url, $env:PUBLIC\\Desktop\\*.url -Force -ErrorAction SilentlyContinue"
        },
        {
            "name": "Install CineIndex",
            "command": "uv tool install git+https://github.com/fahim-ahmed05/cineindex.git"
        },
        {
            "name": "Disable Aria2 Warning in Scoop",
            "command": "scoop config aria2-warning-enabled false"
        }
    ]
}