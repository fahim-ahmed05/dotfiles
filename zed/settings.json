{
  "proxy": "",
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "project_panel": {
    "dock": "left"
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tabs": {
    "file_icons": false,
    "git_status": false
  },
  "scrollbar": {
    "show": "system"
  },
  "toolbar": {
    "quick_actions": true,
    "breadcrumbs": true,
    "selections_menu": true
  },
  "debugger": {
    "button": true
  },
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": true,
    "show": true
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_user_menu": false,
    "show_menus": false,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false
  },
  "auto_update": false,
  "disable_ai": false,
  "terminal": {
    "toolbar": {
      "breadcrumbs": false
    },
    "cursor_shape": "bar",
    "font_weight": 400.0,
    "font_family": "JetBrainsMono Nerd Font",
    "shell": {
      "with_arguments": {
        "program": "pwsh.exe",
        "args": [
          "-NoLogo"
        ]
      }
    }
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  }
}